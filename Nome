<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<title>Comprovante</title>

<style>
body {
  font-family: monospace;
  width: 220px; /* ideal pra 58mm */
  margin: 0 auto;
}

.center {
  text-align: center;
}

hr {
  border: none;
  border-top: 1px dashed black;
  margin: 8px 0;
}

.linha {
  display: flex;
  justify-content: space-between;
}

.input {
  width: 100%;
  margin-bottom: 5px;
}

.big {
  font-size: 18px;
  font-weight: bold;
  text-align: center;
}

@page {
  margin: 0;
}

@media print {
  input, button {
    display: none;
  }
}
</style>

</head>

<body>

<!-- INPUTS -->
<input class="input" placeholder="Número do Ticket" oninput="update('ticket', this.value)">
<input class="input" type="number" placeholder="Peso (kg)" oninput="update('peso', this.value)">
<button onclick="window.print()">🖨️ Imprimir</button>

<hr>

<!-- CUPOM -->
<div>

<div class="center">
